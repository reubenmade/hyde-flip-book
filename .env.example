# ── Required ────────────────────────────────────────────────────────────────

# Neon Postgres connection string (free tier).
# Vercel → Storage → create Neon → copy the pooled connection string.
DATABASE_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Vercel Blob token. Auto-injected on Vercel; set locally for `next dev`.
# Vercel → Storage → Blob → create store → .env tab.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# The single shared admin password.
ADMIN_PASSWORD="change-me-to-something-long"

# Secret used to sign the admin session cookie + hash visitor IPs.
# Generate: openssl rand -base64 32
SESSION_SECRET="change-me-random-32-bytes"

# ── Optional ────────────────────────────────────────────────────────────────

# Force the public base URL used in share links (otherwise derived from request).
# NEXT_PUBLIC_BASE_URL="https://books.hyde.com"
