# ── Required ────────────────────────────────────────────────────────────────

# Postgres connection string. Local Postgres, Supabase, Neon — any standard
# Postgres works (node-postgres driver). For Supabase use the Supavisor pooler
# host (the direct db host is IPv6-only).
DATABASE_URL="postgresql://user:pass@host:5432/dbname"

# Vercel Blob token. Auto-injected on Vercel; set locally for `next dev`.
# Absent locally → images are stored on local disk (./.localblob).
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# Secret used to sign the session cookie + hash visitor IPs.
# Generate: openssl rand -base64 32
SESSION_SECRET="change-me-random-32-bytes"

# ── Superuser (bootstrapped from these on startup) ───────────────────────────
# The superuser manages all other accounts. These env vars are the source of
# truth for this account — changing SUPERUSER_PASSWORD rotates the password.
SUPERUSER_USERNAME="admin"
SUPERUSER_PASSWORD="change-me-to-something-long"
SUPERUSER_EMAIL="you@example.com"

# ── Optional ────────────────────────────────────────────────────────────────

# Password-reset emails (Resend). Without RESEND_API_KEY, reset links are logged
# to the server console instead (fine for local dev).
# RESEND_API_KEY="re_xxx"
# RESEND_FROM="FlyppBook <noreply@your-verified-domain.com>"

# Force the public base URL used in share/reset links (otherwise derived from request).
# NEXT_PUBLIC_BASE_URL="https://books.example.com"
